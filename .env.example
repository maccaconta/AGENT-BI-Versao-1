# ─── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agent_bi_user:agent_bi_pass@localhost:5432/agent_bi_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ─── S3 ────────────────────────────────────────────────────────────────────────
S3_DATALAKE_BUCKET=agent-bi-datalake-123456789012
S3_DASHBOARDS_BUCKET=agent-bi-dashboards-123456789012
S3_ATHENA_RESULTS_BUCKET=agent-bi-athena-results-123456789012

# ─── Glue ──────────────────────────────────────────────────────────────────────
GLUE_DATABASE_PREFIX=agent_bi
GLUE_CRAWLER_ROLE_ARN=arn:aws:iam::123456789012:role/agent-bi-glue-role

# ─── Athena ────────────────────────────────────────────────────────────────────
ATHENA_WORKGROUP=agent-bi-workgroup
ATHENA_OUTPUT_LOCATION=s3://agent-bi-athena-results-123456789012/

# ─── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=8192
USE_BEDROCK_LLM=True
BEDROCK_KB_ID=BJWEDBPNJH
BEDROCK_KB_MAX_RESULTS=5
USE_BEDROCK_AGENT_RUNTIME=False
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_AGENT_ENABLE_TRACE=False
BEDROCK_AGENT_SESSION_PREFIX=agent-bi
BEDROCK_AGENT_IDLE_SESSION_TTL_SECONDS=900
BEDROCK_AGENT_FOUNDATION_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ─── Step Functions ────────────────────────────────────────────────────────────
STEP_FUNCTIONS_REGION=us-east-1
STEP_FUNCTIONS_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:agent-bi-dashboard-pipeline

# ─── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
COGNITO_APP_CLIENT_ID=your-cognito-app-client-id
COGNITO_APP_CLIENT_SECRET=your-cognito-app-client-secret

# ─── CloudFront ────────────────────────────────────────────────────────────────
CLOUDFRONT_DOMAIN=https://d1234567890.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# ─── Security ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Email (SES) ───────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM=noreply@agent-bi.com
SES_REGION=us-east-1

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── App Settings ──────────────────────────────────────────────────────────────
AI_MAX_ITERATIONS=3
AI_MIN_SCORE_THRESHOLD=0.8
MAX_DATASET_SIZE_MB=500
MAX_FILE_ROWS=1000000
LOCAL_DATA_DIR=./local_data
LOCAL_ANALYTICS_SQLITE_PATH=./local_data/analytics/agent_bi_analytics.sqlite
